IRIS_HOST=localhost
IRIS_PORT=52773
IRIS_USERNAME=_SYSTEM
IRIS_PASSWORD=
IRIS_NAMESPACE=HSCUSTOM
IRIS_HTTPS=false

# Default HTTP request timeout in milliseconds (default: 60000).
# Increase if long-running queries or compilations time out.
# Note: Apache's default gateway timeout is ~60s; IIS uses ~120s.
# Per-request timeouts in RequestOptions override this value.
# Health check (5s) and ping (2s) use their own independent timeouts.
IRIS_TIMEOUT=60000
