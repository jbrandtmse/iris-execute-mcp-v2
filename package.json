{
  "name": "iris-mcp-suite",
  "private": true,
  "version": "0.0.0",
  "description": "InterSystems IRIS MCP Server Suite — a monorepo of specialized MCP servers for IRIS",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
